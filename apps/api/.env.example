# Copy this file to .env.development (used when NODE_ENV=development, see src/config.ts)
# and fill in real values. Most hosted Postgres providers require sslmode=require.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE_NAME?sslmode=require"

PORT=8000

# Used to sign/verify auth JWTs (controllers/*, middlewares/token*.ts)
SECRET_JWT="replace-with-a-long-random-secret"

# Used by helpers/notmailer.ts (shared gmail transporter)
MAIL_USER="your-gmail-address@gmail.com"
MAIL_PASS="your-gmail-app-password"

# Used by cron/sendBilling.ts (separate transporter for billing emails)
EMAIL_USER="your-gmail-address@gmail.com"
EMAIL_PASS="your-gmail-app-password"

# Base URLs used to build links in emails/certificates (controllers/*.ts)
BASE_API_URL="http://localhost:8000/api"
BASE_FE_URL="http://localhost:3000"
URL_WEB="http://localhost:3000"

# Used by helpers/cloudinary.ts (file uploads: logos, banners, profile pictures,
# resumes, payment proofs). Create a free account at https://cloudinary.com
# and copy these from your dashboard.
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
