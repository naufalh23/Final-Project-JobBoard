# Copy this file to .env.local and fill in real values.
# Next.js auto-loads .env.local in development; in Vercel, set these
# in Project Settings > Environment Variables instead.

# Must point to a running apps/api instance (local, VPS, or the second
# Vercel project if apps/api is also deployed there).
NEXT_PUBLIC_BASE_API_URL="http://localhost:8000/api"
NEXT_PUBLIC_BASE_WEB_URL="http://localhost:3000"

# From your Supabase project dashboard (used for Facebook/Google social login)
NEXT_PUBLIC_SUPABASE_URL="your-supabase-url"
NEXT_PUBLIC_SUPABASE_KEY="your-supabase-anon-key"
